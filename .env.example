# ─── Supabase ────────────────────────────────────────────────────────────────
#
# Two Supabase projects are in use:
#   Production — holds real user data. Keys set in Vercel → Production environment.
#   Dev        — holds test/demo data. Keys set in Vercel → Preview + Development
#                environments, AND in your local .env.local for local dev.
#
# Leave blank to run in mock/demo mode (no database required).
#
# Production: set in Vercel for the Production environment
# Dev: set in Vercel for Preview/Development environments AND in local .env.local
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ_placeholder

# Server-side only — never prefix with NEXT_PUBLIC_, never commit real value
SUPABASE_SERVICE_ROLE_KEY=eyJ_placeholder_service_role

# ─── PostHog Analytics ───────────────────────────────────────────────────────
# Get from PostHog project settings → Project API key
# Requests are proxied through /ingest — see next.config.ts
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
